# Database Configuration (Neon/PostgreSQL)
# Use sslmode=verify-full for production to avoid warnings and improve reliability
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# Clerk Authentication (Get these from your Clerk Dashboard)
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Cloudinary Storage (Get this from your Cloudinary Settings)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# AI Models & APIs
# Google Gemini API Key
GOOGLE_CLOUD_API_KEY="AIza..."
# Bytez API Key (if using Bytez for generation)
BYTEZ_API_KEY="..."

# Sentry Monitoring (Get this from your Sentry Project)
SENTRY_DSN="https://..."

# Server Settings
PORT=5000
NODE_ENV="development"
# For production, set this to your actual frontend URL (e.g., https://your-app.onrender.com)
ALLOWED_ORIGINS="http://localhost:5173"
